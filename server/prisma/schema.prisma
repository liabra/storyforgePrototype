generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ParticipantRole {
  OWNER
  EDITOR
  VIEWER
}

enum JoinRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model User {
  id            String               @id @default(cuid())
  email         String               @unique
  passwordHash  String
  displayName   String?
  color         String?
  bio           String?
  isAdmin       Boolean              @default(false)
  isBanned      Boolean              @default(false)
  notifBattleEnabled  Boolean        @default(true)
  notifInvitesEnabled Boolean        @default(true)
  notifGeneralEnabled Boolean        @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  characters    Character[]
  contributions Contribution[]
  participations StoryParticipant[]
  joinRequests  JoinRequest[]
  battlesAsAttacker Battle[]         @relation("BattleAttacker")
  battlesAsDefender Battle[]         @relation("BattleDefender")
  battleMoves   BattleMove[]         @relation("BattleMoves")
  battleVotes   BattleVote[]         @relation("BattleVotes")
  battleInvites BattleInvite[]       @relation("BattleInvites")
  reports       Report[]
  notifications Notification[]
}

model Story {
  id           String               @id @default(cuid())
  title        String
  description  String?
  status       ContentStatus        @default(ACTIVE)
  visibility   StoryVisibility      @default(PRIVATE)
  isArchived   Boolean              @default(false)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  chapters     Chapter[]
  characters   Character[]
  participants StoryParticipant[]
  joinRequests JoinRequest[]
}

model JoinRequest {
  id        String            @id @default(cuid())
  storyId   String
  story     Story             @relation(fields: [storyId], references: [id], onDelete: Cascade)
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    JoinRequestStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([storyId, userId])
}

model StoryParticipant {
  id        String          @id @default(cuid())
  storyId   String
  story     Story           @relation(fields: [storyId], references: [id], onDelete: Cascade)
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      ParticipantRole @default(VIEWER)
  createdAt DateTime        @default(now())

  @@unique([storyId, userId])
}

model Chapter {
  id          String        @id @default(cuid())
  title       String
  description String?
  order       Int           @default(0)
  status      ContentStatus @default(ACTIVE)
  storyId     String
  story       Story         @relation(fields: [storyId], references: [id], onDelete: Cascade)
  scenes      Scene[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum SceneStatus {
  DRAFT
  ACTIVE
  DONE
}

enum ContentStatus {
  ACTIVE
  DONE
}

enum StoryVisibility {
  PRIVATE
  PUBLIC
}

enum SceneMode {
  FREE
  TURN
}

model Scene {
  id                String         @id @default(cuid())
  title             String
  description       String?
  imageUrl          String?
  order             Int            @default(0)
  status            SceneStatus    @default(ACTIVE)
  mode              SceneMode      @default(FREE)
  currentTurnUserId String?
  visibilityMode    String         @default("last")
  visibleCount      Int            @default(3)
  chapterId         String
  chapter           Chapter        @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  characters        Character[]    @relation("SceneCharacters")
  contributions     Contribution[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model Contribution {
  id          String     @id @default(cuid())
  content     String
  sceneId     String
  scene       Scene      @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  characterId String?
  character   Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  userId      String?
  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  modStatus   String     @default("OK")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Character {
  id               String         @id @default(cuid())
  name             String?
  nickname         String?
  role             String?
  shortDescription String?
  appearance       String?
  outfit           String?
  accessories      String?
  personality      String?
  traits           String?
  faction          String?
  visualNotes      String?
  avatarUrl        String?
  storyId          String
  story            Story          @relation(fields: [storyId], references: [id], onDelete: Cascade)
  userId           String?
  user             User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  scenes           Scene[]        @relation("SceneCharacters")
  contributions    Contribution[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

// ── Battle mode ─────────────────────────────────────────────────────────────

enum BattleStatus {
  WAITING
  ACTIVE
  VOTING
  DONE
}

enum BattleWinner {
  ATTACKER
  DEFENDER
}

enum BattleInviteRole {
  PLAYER
  SPECTATOR
}

enum BattleInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum PaceMode {
  SYNC
  ASYNC
}

enum BattleEndReason {
  FORFEIT
}

model Battle {
  id                   String           @id @default(cuid())
  title                String
  goal                 String
  status               BattleStatus     @default(WAITING)
  visibility           StoryVisibility  @default(PRIVATE)
  paceMode             PaceMode         @default(ASYNC)
  attackerId           String
  attacker             User             @relation("BattleAttacker", fields: [attackerId], references: [id])
  defenderId           String?
  defender             User?            @relation("BattleDefender", fields: [defenderId], references: [id])
  currentTurnUserId    String?
  turnCount            Int              @default(0)
  minTurns             Int              @default(4)
  maxTurns             Int              @default(8)
  winner               BattleWinner?
  endReason            BattleEndReason?
  lastTurnAt           DateTime?
  turnDeadlineAt       DateTime?
  attackerMissedTurns  Int              @default(0)
  defenderMissedTurns  Int              @default(0)
  moves                BattleMove[]
  votes                BattleVote[]
  invites              BattleInvite[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
}

model BattleInvite {
  id        String             @id @default(cuid())
  battleId  String
  battle    Battle             @relation(fields: [battleId], references: [id], onDelete: Cascade)
  userId    String
  user      User               @relation("BattleInvites", fields: [userId], references: [id])
  role      BattleInviteRole
  status    BattleInviteStatus @default(PENDING)
  expiresAt DateTime?
  createdAt DateTime           @default(now())

  @@unique([battleId, userId])
}

model BattleMove {
  id         String   @id @default(cuid())
  battleId   String
  battle     Battle   @relation(fields: [battleId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("BattleMoves", fields: [userId], references: [id])
  content    String
  turnNumber Int
  createdAt  DateTime @default(now())
}

model BattleVote {
  id        String   @id @default(cuid())
  battleId  String
  battle    Battle   @relation(fields: [battleId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("BattleVotes", fields: [userId], references: [id])
  vote      Boolean
  createdAt DateTime @default(now())

  @@unique([battleId, userId])
}

// ── Reports ──────────────────────────────────────────────────────────────────

enum ReportTargetType {
  CONTRIBUTION
  BATTLE_MOVE
  STORY
}

enum ReportStatus {
  OPEN
  IGNORED
  RESOLVED
}

model Report {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetType ReportTargetType
  targetId   String
  reason     String?
  status     ReportStatus     @default(OPEN)
  createdAt  DateTime         @default(now())

  @@unique([userId, targetType, targetId])
}

// ── Notifications ─────────────────────────────────────────────────────────────

enum NotificationType {
  CONTENT_REMOVED
  USER_BANNED
  USER_UNBANNED
  BATTLE_INVITE
  STORY_INVITE
  GENERAL
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
}
