generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Story {
  id          String      @id @default(cuid())
  title       String
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  characters  Character[]
  scenes      Scene[]
}

model Character {
  id               String   @id @default(cuid())
  name             String?
  nickname         String?
  role             String?
  shortDescription String?
  appearance       String?
  outfit           String?
  accessories      String?
  personality      String?
  traits           String?
  faction          String?
  visualNotes      String?
  storyId          String
  story            Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Scene {
  id             String   @id @default(cuid())
  title          String
  content        String?
  imageUrl       String?
  order          Int      @default(0)
  visibilityMode String   @default("last_lines")
  visibleLines   Int      @default(3)
  storyId        String
  story          Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
